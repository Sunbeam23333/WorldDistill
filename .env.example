# ============================================================================
# WorldDistill Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# --- Proxy Configuration (for downloading models from HuggingFace) ---
# If your network requires a proxy, configure these:
# PROXY_USERNAME=your_username
# PROXY_PASSWORD=your_password
# PROXY_HOST=your_proxy_host
# PROXY_PORT=your_proxy_port

# Or set proxy URL directly:
# HTTP_PROXY=http://user:pass@host:port
# HTTPS_PROXY=http://user:pass@host:port

# --- Model Storage ---
# Root directory for downloaded models (default: ./models)
MODEL_ROOT=./models

# --- Results ---
# Root directory for inference/training outputs (default: ./results)
RESULT_ROOT=./results

# --- HuggingFace ---
# HF_TOKEN=your_huggingface_token  # Optional, for gated models
