{
    "distill_method": "context_forcing",
    "description": "Memory-aware context forcing distillation. Aligns teacher/student memory context to prevent error drift in autoregressive world models.",
    "num_inference_steps": 4,
    "memory_frames": 20,
    "temporal_context_size": 12,
    "curriculum_training": true,
    "curriculum_stages": [32, 64, 96, 128, 160],
    "optimizer": "muon",
    "learning_rate": 1e-5,
    "weight_decay": 0.0,
    "max_grad_norm": 10.0,
    "warmup_steps": 500,
    "mixed_precision": "bf16",
    "gradient_checkpointing": true,
    "enable_runtime": true,
    "runtime_name": "world_model",
    "runtime_enable_dpp": true,
    "enable_fused_supervision_kernel": true,
    "fused_supervision_backend": "triton",
    "generator_update_interval": 5,
    "notes": "Reference: HY-WorldPlay Context Forcing distillation"
}
