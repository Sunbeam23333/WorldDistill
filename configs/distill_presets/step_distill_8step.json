{
    "method": "step_distill",
    "description": "Fixed 8-step distillation for higher quality.",
    "num_inference_steps": 8,
    "denoising_step_list": [1000, 875, 750, 625, 500, 375, 250, 125],
    "use_cfg": false,
    "dual_model": false,
    "loss": "mse",
    "optimizer": "adamw",
    "learning_rate": 1e-5,
    "weight_decay": 0.0,
    "gradient_clip": 1.0,
    "warmup_steps": 500,
    "mixed_precision": "bf16",
    "gradient_checkpointing": true
}
