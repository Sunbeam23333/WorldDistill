{
    "method": "step_distill",
    "description": "Fixed 4-step distillation. Teacher generates targets at fixed timesteps, student learns direct prediction.",
    "num_inference_steps": 4,
    "denoising_step_list": [1000, 750, 500, 250],
    "use_cfg": false,
    "dual_model": true,
    "boundary_step_index": 2,
    "loss": "mse",
    "optimizer": "adamw",
    "learning_rate": 1e-5,
    "weight_decay": 0.0,
    "gradient_clip": 1.0,
    "warmup_steps": 500,
    "mixed_precision": "bf16",
    "gradient_checkpointing": true
}
